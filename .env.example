# ── MongoDB ──
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/portfolio?retryWrites=true&w=majority
MONGODB_DB=portfolio

# ── Admin API Key (shared secret between frontend and API) ──
ADMIN_API_KEY=your-secret-admin-key

# ── Frontend env vars (VITE_ prefix required) ──
VITE_API_URL=/api
VITE_ADMIN_API_KEY=your-secret-admin-key
VITE_BOT_URL=http://localhost:3001
